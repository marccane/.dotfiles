ocrCatala() {
    local input="$1"
    local output="${input%.*}"
    if [[ -f "${output}.txt" ]]; then
        echo "Output file '${output}.txt' already exists. Overwrite? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy]$ ]] || return 1
    fi
    tesseract "$input" "$output" -l cat
}

claudeSessions() {
    find ~/.claude/projects/ -name "*.jsonl" -printf "%T@ %Tc %p\n" | sort -rn | awk '{$1=""; print NR". "$0}' | tac
}

claudeResume() {
    local index=$1
    local line=$(find ~/.claude/projects/ -name "*.jsonl" -printf "%T@ %p\n" | sort -rn | sed -n "${index}p")
    local filepath="${line##* }"

    if [[ -z "$filepath" ]]; then
        echo "No session found at index $index"
        return 1
    fi

    local uuid=$(basename "$filepath" .jsonl)
    local encoded=$(basename "$(dirname "$filepath")")

    local project_dir=$(python3 - "$encoded" <<'EOF'
import os, sys

def find_path(encoded):
    parts = encoded.lstrip('-').split('-')

    def reconstruct(parts, current_path):
        if not parts:
            return current_path
        try:
            entries = [e for e in os.listdir(current_path) if os.path.isdir(os.path.join(current_path, e))]
        except (PermissionError, FileNotFoundError):
            return None
        for entry in sorted(entries):
            entry_parts = entry.replace('_', '-').split('-')
            n = len(entry_parts)
            if parts[:n] == entry_parts:
                result = reconstruct(parts[n:], os.path.join(current_path, entry))
                if result is not None:
                    return result
        return None

    return reconstruct(parts, '/')

print(find_path(sys.argv[1]) or "")
EOF
)

    echo "Session : $uuid"
    echo "Project : $project_dir"

    if [[ -n "$project_dir" && -d "$project_dir" ]]; then
        cd "$project_dir" && claude --resume "$uuid"
    else
        echo "Error: could not resolve project directory for: $encoded"
        return 1
    fi
}

ocrEnglish() {
    local input="$1"
    local output="${input%.*}"
    if [[ -f "${output}.txt" ]]; then
        echo "Output file '${output}.txt' already exists. Overwrite? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy]$ ]] || return 1
    fi
    tesseract "$input" "$output" -l eng
}

git() {
    if [[ $1 == "clone" ]]; then
	shift
        command git clone --recursive "$@"
    else
        command git "$@"
    fi
}

function mountTemp(){
    device="$1"
    shift
    sudo mount "$device" /mnt/temp "$@"
}

function hex2string () {
  if [ "$#" -eq 0 ]; then
    while read line
    do
      hex2string $line
    done
  else
    while [ "$#" -gt 1 ]; do
      hex2string $1
      shift 1
    done
    I=0
    while [ $I -lt ${#1} ];
    do
      echo -en "\x"${1:$I:2}
      let "I += 2"
    done
    echo ""
  fi
}

windowinfo() {
    sleep 1
    local wid pid
    wid=$(xdotool getactivewindow)
    pid=$(xdotool getwindowpid "$wid" 2>/dev/null)
    printf "Win ID:  %s\nName:    %s\nPID:     %s\nProcess: %s\nClass:   %s\n" \
      "$wid" \
      "$(xdotool getwindowname "$wid")" \
      "${pid:--}" \
      "$(ps -p "$pid" -o comm= 2>/dev/null || echo -)" \
      "$(xprop -id "$wid" WM_CLASS 2>/dev/null | cut -d= -f2)"
  }
alias wininfo=windowinfo

7zpassword() {
      if [[ $# -lt 3 ]]; then
          echo "Usage: 7zpassword <archive.7z> <password> <file|dir> [...]"
          return 1
      fi
      local archive="$1"
      local password="$2"
      shift 2
      7z a -p"$password" -mhe=on "$archive" "$@"
  }

#https://www.linuxfordevices.com/tutorials/linux/extract-compressed-files-custom-command
extract() {
  if [ -f "$1" ] ; then
    case "$1" in
      *.a)         ar x "$1"                  ;;
      *.deb)       dpkg-deb -X "$1" .         ;;
      *.tar.*)     tar xvf "$1"               ;;
      *.tar)       tar xvf "$1"               ;;
      *.tbz2)      tar xvjf "$1"              ;;
      *.tgz)       tar xvzf "$1"              ;;
      *.bz2)       bunzip2 "$1"               ;;
      *.rar)       unrar x "$1"               ;;
      *.gz)        gunzip "$1"                ;;
      *.zip)       unzip "$1"                 ;;
      *.jar)       unzip "$1"                 ;;
      *.xpi)       unzip "$1"                 ;;
      *.apk)       unzip "$1"                 ;;
      *.war)       unzip "$1"                 ;;
      *.ear)       unzip "$1"                 ;;
      *.whl)       unzip "$1"                 ;;
      *.crx)       unzip "$1"                 ;;
      *.epub)      unzip "$1"                 ;;
      *.xz)        xz -d "$1"                 ;;
      *.zst)       zstd -d "$1"               ;;
      *.lz4)       lz4 -d "$1"                ;;
      *.rpm)       rpm2cpio "$1" | cpio -idmv ;;
      *.iso)       7z x "$1"                  ;;
      *.Z)         uncompress "$1"            ;;
      *.7z)        7z x "$1"                  ;;
      *.cab)       cabextract "$1"            ;;
      *)           echo "don't know how to extract '$1'..." ;;
    esac
  else
    echo "'$1' is not a valid file!"
  fi
}

contents() {
  if [ -f "$1" ] ; then
    case "$1" in
      *.a)         ar t "$1"                  ;;
      *.deb)       dpkg-deb -c "$1"           ;;
      *.tar.*)     tar tvf "$1"               ;;
      *.tar)       tar tvf "$1"               ;;
      *.tbz2)      tar tvf "$1"               ;;
      *.tgz)       tar tvf "$1"               ;;
      *.rar)       unrar v "$1"               ;;
      *.zip)       unzip -l "$1"              ;;
      *.jar)       unzip -l "$1"              ;;
      *.xpi)       unzip -l "$1"              ;;
      *.apk)       unzip -l "$1"              ;;
      *.war)       unzip -l "$1"              ;;
      *.ear)       unzip -l "$1"              ;;
      *.whl)       unzip -l "$1"              ;;
      *.crx)       unzip -l "$1"              ;;
      *.epub)      unzip -l "$1"              ;;
      *.xz)        xz -l "$1"                 ;;
      *.zst)       zstd -l "$1"               ;;
      *.rpm)       rpm -qlp "$1"              ;;
      *.iso)       7z l "$1"                  ;;
      *.7z)        7z l "$1"                  ;;
      *.cab)       cabextract -l "$1"         ;;
      *)           echo "don't know how to list '$1'..." ;;
    esac
  else
    echo "'$1' is not a valid file!"
  fi
}

#https://unix.stackexchange.com/a/163716
_alarm() {
  ( \speaker-test --frequency $1 --test sine )&
  pid=$!
  \sleep 0.${2}s
  \kill -9 $pid
}

