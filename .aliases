# =============================================================================
# Arch package dependencies for all commands referenced in this file.
# Items marked (MISSING) are not currently installed on this system.
# Items marked (AUR) are typically only available from the AUR / custom repos.
# =============================================================================
#
# Core utilities (coreutils, etc.):
#   coreutils, findutils, gawk, sed, grep, less, file, diffutils,
#   util-linux, procps-ng, iproute2, net-tools, inetutils, openssh,
#   kmod, systemd, sudo, perl, python, nano, jq, curl, rsync, watch,
#   safe-rm
#
# Archive / compression tools (extract, contents, 7zpassword):
#   tar, gzip, bzip2, xz, zstd, lz4, unzip, unrar, 7zip, cabextract,
#   binutils (ar, objdump), dpkg, cpio (MISSING), rpm-tools (MISSING)
#
# Pacman / AUR helpers (pkginfo, fixPacmanKeyring, whichPackage, ...):
#   pacman, pacman-contrib (pactree), yay-bin
#
# Xorg / desktop helpers (windowinfo, setxkb, inputdebug, ...):
#   xdotool, xorg-xprop, xorg-xev, xorg-setxkbmap, xclip
#
# Audio / multimedia (whiteNoise, equalizer, soundControl, fasttracker):
#   alsa-utils (speaker-test), pulseaudio-equalizer (qpaeq),
#   pavucontrol, vlc-cli (cvlc), ft2-clone, imagemagick (mogrify),
#   pulseeffects-legacy / easyeffects (MISSING)
#
# Notifications / GUI integration:
#   libnotify (notify-send), network-manager-applet (nm-applet),
#   nautilus, flatpak
#
# Window manager / compositor / wallpaper:
#   picom, nitrogen, feh
#
# Editors / IDEs (notepad*, code, *Config aliases):
#   vscodium-bin (codium), mousepad, gedit, xed,
#   leafpad (MISSING, AUR)
#
# Image / dup-file tools:
#   digikam, geeqie, kolourpaint, czkawka-gui-bin,
#   findimagedupes, rdfind
#
# Music / podcasts:
#   clementine (MISSING)
#
# Reverse engineering / hex editors:
#   wxhexeditor, bless, fhex, ghex,
#   iaito (MISSING, AUR)
#
# Document viewers / readers (pdf, md, rssreader):
#   evince, okular, liferea, bat
#
# Web browsers:
#   firefox, epiphany, chromium, lynx, midori
#
# VNC clients / servers:
#   tigervnc (vncviewer, Xvnc), vncdotool (vncdo), x11vnc,
#   gtk-vnc (gvncviewer, MISSING), vinagre (MISSING)
#
# Emulation / handheld dev (ard, send3dsx, brew, citra*, nds*, ...):
#   arduino-cli, 3dslink (devkitpro repo),
#   azahar-appimage (citra successor), desmume, melonds-bin,
#   ninfs-gui, blobsaver-bin,
#
# Torrents:
#   transmission-qt, deluge
#
# Git / dotfiles:
#   git, gittyup, praise (gitblame alias)
#
# Process / system info:
#   qps, udisks2 (udisksctl), libvirt (virsh)
#
# Settings managers:
#   xfce4-settings (xfce4-settings-manager),
#   plasma-workspace (systemsettings)
#
# Bluetooth (cascos, pinganillosCasa, btdisconnect):
#   bluez-utils (bluetoothctl)
#
# Network / scanning / geo:
#   nmap, geoip (geoiplookup)
#
# OCR (ocrCatala, ocrEnglish):
#   tesseract, tesseract-data-cat, tesseract-data-eng
#
# Misc / esoteric:
#   solaar, ddcutil-git,
#   markdown2pdf (alternative: pandoc + texlive)
#
# Security tools (checksec2):
#   checksec, python-pwntools
#
# Not pacman-managed (informational):
#   claude (claude-code, via npm),
#   PTCUtilities.sh, cascos.sh, pinganillosCasa.sh, claude_usage.py
#     — personal scripts under ~/.scripts and ~/canethings
# =============================================================================

realdir() {
        cd "$(realpath .)"
}

pkginfo() {
	yay -Qi $1
	echo "#########################"
	pactree -r $1
}

ard() {
	arduino-cli compile --fqbn arduino:avr:uno --upload --port /dev/ttyACM0 *.ino
}

path() {
	echo $PATH | sed 's/:/\n/g'
}

claudeUsageWatch() {  # no arg lists orgs; pass name substring to select (e.g. personal, troax)
	watch -c -n 180 "claude_usage.py${1:+ $1}";
}

# Resolve a single .3dsx target from an argument.
# Dir arg  -> most recent *.3dsx in it (non-recursive).
# File arg -> itself (must have a .3dsx extension).
# Prints the path on success; error to stderr + returns 1 on failure.
_resolve3dsx() {
	local arg="$1" file ext
	if [ -d "$arg" ]; then
		file=$(find "$arg" -maxdepth 1 -type f -iname '*.3dsx' -printf '%T@ %p\n' 2>/dev/null \
		       | sort -rn | head -n1 | cut -d' ' -f2-)
		if [ -z "$file" ]; then
			echo "3dsx: no .3dsx file found in '$arg'" >&2
			return 1
		fi
		printf '%s\n' "$file"
	elif [ -f "$arg" ]; then
		ext=$(printf '%s' "${arg##*.}" | tr '[:upper:]' '[:lower:]')
		if [ "$ext" != "3dsx" ]; then
			echo "3dsx: not a .3dsx file: '$arg'" >&2
			return 1
		fi
		printf '%s\n' "$arg"
	else
		echo "3dsx: no such file or directory: '$arg'" >&2
		return 1
	fi
}

send3dsx() {
	if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
		echo "Usage: send3dsx [file.3dsx | directory]"
		echo "  (no arg)    send the most recent *.3dsx in the current directory"
		echo "  directory   send the most recent *.3dsx in it (non-recursive)"
		echo "  file.3dsx   send that specific file"
		echo "Retries via 3dslink until the transfer succeeds."
		return 0
	fi
	local target result=1
	target=$(_resolve3dsx "${1:-.}") || return 1
	echo "Sending: $target"
	while [ $result -ne 0 ] ; do
	        command 3dslink "$target"
		result=$?
	done
}

brew() {
	if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
		echo "Usage: brew [file.3dsx | directory]"
		echo "  (no arg)    launch the most recent *.3dsx in the current directory"
		echo "  directory   launch the most recent *.3dsx in it (non-recursive)"
		echo "  file.3dsx   launch that specific file"
		echo "Runs the .3dsx in the azahar emulator."
		return 0
	fi
	local target
	target=$(_resolve3dsx "${1:-.}") || return 1
	echo "Launching: $target"
	azahar "$target"
}

# Override 3dslink to route through send3dsx (which itself uses `command 3dslink`,
# so no recursion). Args after the alias are appended, e.g. `3dslink ~/builds`.
alias 3dslink='echo "redirecting to send3dsx" && send3dsx'

ocrCatala() {
    local input="$1"
    local output="${input%.*}"
    if [[ -f "${output}.txt" ]]; then
        echo "Output file '${output}.txt' already exists. Overwrite? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy]$ ]] || return 1
    fi
    tesseract "$input" "$output" -l cat
}

claudeSessions() {
    find ~/.claude/projects/ -name "*.jsonl" -printf "%T@ %Tc %p\n" | sort -rn | awk '{$1=""; print NR". "$0}' | tac
}

claudeResume() {
    local index=""
    local claude_args=()
    for arg in "$@"; do
        if [[ -z "$index" && "$arg" =~ ^[0-9]+$ ]]; then
            index="$arg"
        else
            claude_args+=("$arg")
        fi
    done

    if [[ -z "$index" ]]; then
        echo "Usage: claudeResume <index> [claude flags...]"
        return 1
    fi

    local line=$(find ~/.claude/projects/ -name "*.jsonl" -printf "%T@ %p\n" | sort -rn | sed -n "${index}p")
    local filepath="${line##* }"

    if [[ -z "$filepath" ]]; then
        echo "No session found at index $index"
        return 1
    fi

    local uuid=$(basename "$filepath" .jsonl)
    local encoded=$(basename "$(dirname "$filepath")")

    local project_dir=$(python3 - "$encoded" <<'EOF'
import os, sys

def find_path(encoded):
    parts = encoded.lstrip('-').split('-')

    def reconstruct(parts, current_path):
        if not parts:
            return current_path
        try:
            entries = [e for e in os.listdir(current_path) if os.path.isdir(os.path.join(current_path, e))]
        except (PermissionError, FileNotFoundError):
            return None
        for entry in sorted(entries):
            entry_parts = entry.replace('_', '-').split('-')
            n = len(entry_parts)
            if parts[:n] == entry_parts:
                result = reconstruct(parts[n:], os.path.join(current_path, entry))
                if result is not None:
                    return result
        return None

    return reconstruct(parts, '/')

print(find_path(sys.argv[1]) or "")
EOF
)

    echo "Session : $uuid"
    echo "Project : $project_dir"

    if [[ -n "$project_dir" && -d "$project_dir" ]]; then
        cd "$project_dir" && claude "${claude_args[@]}" --resume "$uuid"
    else
        echo "Error: could not resolve project directory for: $encoded"
        return 1
    fi
}

ocrEnglish() {
    local input="$1"
    local output="${input%.*}"
    if [[ -f "${output}.txt" ]]; then
        echo "Output file '${output}.txt' already exists. Overwrite? [y/N] "
        read -r answer
        [[ "$answer" =~ ^[Yy]$ ]] || return 1
    fi
    tesseract "$input" "$output" -l eng
}

git() {
    if [[ $1 == "clone" ]]; then
	shift
        command git clone --recursive "$@"
    else
        command git "$@"
    fi
}

function mountTemp(){
    device="$1"
    shift
    sudo mount "$device" /mnt/temp "$@"
}

function hex2string () {
  if [ "$#" -eq 0 ]; then
    while read line
    do
      hex2string $line
    done
  else
    while [ "$#" -gt 1 ]; do
      hex2string $1
      shift 1
    done
    I=0
    while [ $I -lt ${#1} ];
    do
      echo -en "\x"${1:$I:2}
      let "I += 2"
    done
    echo ""
  fi
}

windowinfo() {
    sleep 1
    local wid pid
    wid=$(xdotool getactivewindow)
    pid=$(xdotool getwindowpid "$wid" 2>/dev/null)
    printf "Win ID:  %s\nName:    %s\nPID:     %s\nProcess: %s\nClass:   %s\n" \
      "$wid" \
      "$(xdotool getwindowname "$wid")" \
      "${pid:--}" \
      "$(ps -p "$pid" -o comm= 2>/dev/null || echo -)" \
      "$(xprop -id "$wid" WM_CLASS 2>/dev/null | cut -d= -f2)"
  }
alias wininfo=windowinfo

7zpassword() {
      if [[ $# -lt 3 ]]; then
          echo "Usage: 7zpassword <archive.7z> <password> <file|dir> [...]"
          return 1
      fi
      local archive="$1"
      local password="$2"
      shift 2
      7z a -p"$password" -mhe=on "$archive" "$@"
  }

#https://www.linuxfordevices.com/tutorials/linux/extract-compressed-files-custom-command
extract() {
  if [ -f "$1" ] ; then
    case "$1" in
      *.a)         ar x "$1"                  ;;
      *.deb)       dpkg-deb -X "$1" .         ;;
      *.tar.*)     tar xvf "$1"               ;;
      *.tar)       tar xvf "$1"               ;;
      *.tbz2)      tar xvjf "$1"              ;;
      *.tgz)       tar xvzf "$1"              ;;
      *.bz2)       bunzip2 "$1"               ;;
      *.rar)       unrar x "$1"               ;;
      *.gz)        gunzip "$1"                ;;
      *.zip)       unzip "$1"                 ;;
      *.jar)       unzip "$1"                 ;;
      *.xpi)       unzip "$1"                 ;;
      *.apk)       unzip "$1"                 ;;
      *.war)       unzip "$1"                 ;;
      *.ear)       unzip "$1"                 ;;
      *.whl)       unzip "$1"                 ;;
      *.crx)       unzip "$1"                 ;;
      *.epub)      unzip "$1"                 ;;
      *.xz)        xz -d "$1"                 ;;
      *.zst)       zstd -d "$1"               ;;
      *.lz4)       lz4 -d "$1"                ;;
      *.rpm)       rpm2cpio "$1" | cpio -idmv ;;
      *.iso)       7z x "$1"                  ;;
      *.Z)         uncompress "$1"            ;;
      *.7z)        7z x "$1"                  ;;
      *.cab)       cabextract "$1"            ;;
      *)           echo "don't know how to extract '$1'..." ;;
    esac
  else
    echo "'$1' is not a valid file!"
  fi
}

contents() {
  if [ -f "$1" ] ; then
    case "$1" in
      *.a)         ar t "$1"                  ;;
      *.deb)       dpkg-deb -c "$1"           ;;
      *.tar.*)     tar tvf "$1"               ;;
      *.tar)       tar tvf "$1"               ;;
      *.tbz2)      tar tvf "$1"               ;;
      *.tgz)       tar tvf "$1"               ;;
      *.rar)       unrar v "$1"               ;;
      *.zip)       unzip -l "$1"              ;;
      *.jar)       unzip -l "$1"              ;;
      *.xpi)       unzip -l "$1"              ;;
      *.apk)       unzip -l "$1"              ;;
      *.war)       unzip -l "$1"              ;;
      *.ear)       unzip -l "$1"              ;;
      *.whl)       unzip -l "$1"              ;;
      *.crx)       unzip -l "$1"              ;;
      *.epub)      unzip -l "$1"              ;;
      *.xz)        xz -l "$1"                 ;;
      *.zst)       zstd -l "$1"               ;;
      *.rpm)       rpm -qlp "$1"              ;;
      *.iso)       7z l "$1"                  ;;
      *.7z)        7z l "$1"                  ;;
      *.cab)       cabextract -l "$1"         ;;
      *)           echo "don't know how to list '$1'..." ;;
    esac
  else
    echo "'$1' is not a valid file!"
  fi
}

#https://unix.stackexchange.com/a/163716
