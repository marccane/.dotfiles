alias pyenvVersions="ls ~/.pyenv/versions/"
alias setxkb="setxkbmap es,ru -option grp:alt_shift_toggle"
alias tojpg="mogrify -format jpg -quality 95"
alias whiteNoise="cvlc ~/Sounds/03-White-Noise-10min.mp3"
alias decolorize="sed 's/\x1B\[[0-9;]\{1,\}[A-Za-z]//g'"
alias fixPacmanKeyring="sudo pacman -S archlinux-keyring"
alias editPacmanConfigGUI="sudo leafpad /etc/pacman.conf"
alias pacmanRemoveUnstableRepos="sudo sed -i 's/^\([^#].*\(dkp-libs\|dkp-linux\|pkg\.devkitpro\).*\)$/#\1/' /etc/pacman.conf"
alias pacmanAddUnstableRepos="sudo sed -i 's/^#\(.*\(dkp-libs\|dkp-linux\|pkg\.devkitpro\).*\)$/\1/' /etc/pacman.conf"
alias ip2geo=geoiplookup
alias dotfiles='/usr/bin/git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'
alias dfs="dotfiles status"
alias dfd="dotfiles diff"
alias dfdc="dotfiles diff --cached"
alias dfa="dotfiles add"
alias dfc="dotfiles commit"
alias dfp="dotfiles push"
alias prettyjson="jq . "
alias citraLog="cat ~/.local/share/citra-emu/log/citra_log.txt"
alias citraLogDir=~/.local/share/citra-emu/log/
alias citraDir=~/.local/share/citra-emu/
alias reloadZsh="source ~/.zshrc"
alias reload=reloadZsh
alias brilloBenq="starti2c && sudo ddcutil --bus 4 setvcp 0x10 > /dev/null"
alias benqvga="starti2c && sudo ddcutil --bus 4 setvcp 0x60 0x1 > /dev/null"
alias benqhdmi="starti2c && sudo ddcutil --bus 4 setvcp 0x60 0x11 > /dev/null"
alias benqhdmi2="starti2c && sudo ddcutil --bus 4 setvcp 0x60 0x12 > /dev/null"
alias brilloAcer="starti2c && sudo ddcutil --bus 10 setvcp 0x10 > /dev/null"
alias bb=brilloBenq
alias ba=brilloAcer
alias cpProgress="rsync -ah --progress"
alias stdinToClipboard="xclip -selection c"
alias toclipboard="xclip -selection c"
alias nanolines="nano -l"
alias nanowrap="nano -S"
alias cascos="startbt && cascos.sh" #cascos.sh is a bash script wich does "bluetoothctl connect XX:XX:XX:XX:XX:XX"
alias pinganillosCasa="startbt && pinganillosCasa.sh"
alias cascosdisconnect="bluetoothctl disconnect"
alias btdisconnect="bluetoothctl disconnect"
alias networkUsage="watch -n1 ifconfig enp33s0"
alias androidFtp="ftp android@192.168.1.245 -p 2221"
alias flatpakPackageSizes="flatpak list --columns=size,name|sort -g"
alias mountNtfsWritePermissionsAllUsers="sudo mount -o user,umask=0000"
alias mountFatWritePermissionsAllUsers="sudo mount -o user,umask=0000"
alias umountTemp="sudo umount /mnt/temp"
alias utemp=umountTemp
alias localdevices="nmap -sn 192.168.1.1/24 | grep -o '[0-9]\?[0-9]\?[0-9]\.[0-9]\?[0-9]\?[0-9]\.[0-9]\?[0-9]\?[0-9]\.[0-9]\?[0-9]\?[0-9]'"
alias fakebeep="_alarm 1000 400 >/dev/null"
alias gits="git status"
alias gitb="git branch | cat"
alias gitc="git checkout"
alias gitd="git diff"
alias gitdc="git diff --cached"
alias gitadog="git log --all --decorate --oneline --graph" #CLI branch graph
alias fixbrillo="sudo ddcutil detect"
alias fixKvmNetwork="sudo virsh net-start default"
alias crashes="coredumpctl list"
alias stophdd="sudo udisksctl power-off -b /dev/sda" #sudo permission in /etc/sudoers allows to execute without passwd
alias hibernacioNormal="sudo cp -f /etc/systemd/sleep.conf.normal /etc/systemd/sleep.conf" #perquè no rebooteji després d'hibernar
alias printGitRepoRemotes="find -maxdepth 5 -type d -name ".git" 2>/dev/null | grep -v "\.cache" | xargs -I{} bash -c 'cd {}; cd ..; echo; echo '{}'; git remote -v'"
alias alaconfig="nano ~/.config/alacritty/alacritty.toml"
alias secureRm="shred -ufv -n1 --remove=wipe"
alias pacmanConfig="sudo nano /etc/pacman.conf"
alias yayConfig="nano ~/.config/yay/config.json"
alias alacrittyConfig="nano .config/alacritty/alacritty.toml"
alias gigawin="ssh gigabyte_windows"
alias citra=azahar
alias claudeTelegramNotificationsEnable="echo 1 > ~/.claude/telegram_notifications_enabled && echo 'Claude Telegram notifications enabled'"
alias claudeTelegramNotificationsDisable="echo 0 > ~/.claude/telegram_notifications_enabled && echo 'Claude Telegram notifications disabled'"
alias checksec2="py /usr/lib/python3.14/site-packages/pwnlib/commandline/checksec.py"
alias claudeCodeChatRegenerate="python ~/repos/code-chat-viewer/scripts/manager.py"
alias claudeCodeChatOpen="firefox ~/.CodeChatViewer/CCV-Dashboard.html"
alias dangerousClaude="claude --dangerously-skip-permissions"
alias histfileView="awk 'match(\$0,/^: [0-9]+:[0-9]+;/){ split(substr(\$0,3,RLENGTH-3),a,\":\"); printf \": %s:%s;%s\n\", strftime(\"%d/%m/%y %H:%M\",a[1]), a[2], substr(\$0,RLENGTH+1) }' ~/.histfile | less"
alias claudeResumeDangerous="claudeResume --dangerously-skip-permissions"
alias claudeResumeDangerousLatestSession="claudeResumeDangerous 1"
alias tl=toggle_ledvance_plug.py
alias ts=toggle_shelly_plug.py
