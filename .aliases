git() {
    if [[ $1 == "clone" ]]; then
	shift
        command git clone --recursive "$@"
    else
        command git "$@"
    fi
}

function mountTemp(){
    device=$1
    shift
    sudo mount $device /mnt/temp $@
}

function hex2string () {
  if [ "$#" -eq 0 ]; then
    while read line
    do
      hex2string $line
    done
  else
    while [ "$#" -gt 1 ]; do
      hex2string $1
      shift 1
    done
    I=0
    while [ $I -lt ${#1} ];
    do
      echo -en "\x"${1:$I:2}
      let "I += 2"
    done
    echo ""
  fi
}

#https://www.linuxfordevices.com/tutorials/linux/extract-compressed-files-custom-command
extract() {
  if [ -f $1 ] ; then
    case $1 in
      *.tar.bz2)    tar xvjf $1    ;;
      *.tar.gz)    tar xvzf $1    ;;
      *.tar.xz)    tar xvf $1      ;;
      *.tar)        tar xvf $1     ;;
      *.tbz2)        tar xvjf $1    ;;
      *.tgz)        tar xvzf $1    ;;
      *.bz2)        bunzip2 $1     ;;
      *.rar)        unrar x $1     ;;
      *.gz)        gunzip $1      ;;
      *.zip)        unzip $1       ;;
      *.jar)        unzip $1       ;;
      *.Z)        uncompress $1  ;;
      *.7z)        7z x $1        ;;
      *.cab)        cabextract $1        ;;
      *)        echo "don't know how to extract '$1'..." ;;
    esac
  else
    echo "'$1' is not a valid file!"
  fi
}

contents() {
  if [ -f $1 ] ; then
    case $1 in
      *.tar.bz2)    tar tvf $1    ;;
      *.tar.gz)    tar tvf $1    ;;
      *.tar.xz)    tar tvf $1      ;;
      *.tar)        tar tvf $1     ;;
      *.tbz2)        tar tvf $1    ;;
      *.tgz)        tar tvf $1    ;;
#      *.bz2)        bunzip2 ??? $1     ;;
      *.rar)        unrar v $1     ;;
      *.zip)        unzip -l $1       ;;
      *.jar)        unzip -l $1       ;;
      *.7z)        7z l $1        ;;
      *.cab)        cabextract -l $1        ;;
      *)        echo "don't know how to list '$1'..." ;;
    esac
  else
    echo "'$1' is not a valid file!"
  fi
}

#https://unix.stackexchange.com/a/163716
_alarm() {
  ( \speaker-test --frequency $1 --test sine )& disown
  pid=$!
  \sleep ${2}s
  \kill -9 $pid
}

#STDERR printed in RED. Example: color ping
color()(set -o pipefail;"$@" 2> >(sed $'s,.*,\e[31m&\e[m,'>&2))

#Example of multiple strings with grep (or): grep -E 'str1|str2'
#Search regular files that are executable: find -type f --executable
#Aliases limitation: they don't work with $mod + d
#Find's parameter for directory depth limit is -maxdepth X, not -depth X
#Example of find with multiple file extensions find \( -iname \*.h -o -iname \*.cpp -o -iname \*.c \)

#Warning: in bash functions cannot be oneliners, for compatibility make them 3 lines
# wrap long lines using backslashes
wrap() { 
	perl -pe 's/.{'$(( ${COLUMNS:-80} - 1))'}/$&\\\n/g' -- "$@" 
}
# create a 256M ramdisk
alias ramdisk='sudo mount -t tmpfs -o size=256m tmpfs /mnt/ramdisk && cd /mnt/ramdisk'
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias grep="grep --color=auto"
alias fgrep="fgrep --color=auto"
alias egrep="egrep --color=auto"
mkd() { 
	mkdir -p "$1" && cd "$1" 
}
exe() { 
	chmod a+x "$1" 
}

removeTrailingWhitespaces() { #supports multiple files!
    if [ "$#" -eq 0 ]; then
        printf "Usage: removeTrailingWhitespaces <file1> [file2 ...]\n" >&2
        return 1
    fi

    for file in "$@"; do
        if [ -f "$file" ]; then
            sed -i 's/[[:space:]]\+$//' "$file"
        else
            printf "Skipping: '%s' is not a file\n" "$file" >&2
        fi
    done
}

