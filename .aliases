# Cherry-pick a commit from the current dotfiles branch onto the "other"
# branch via the ~/.dotfiles_master worktree, then push both sides.
# Target branch resolution: <branch> arg > `git config share.target` (required if no arg).
# Set the per-machine target with: git --git-dir=$HOME/.dotfiles --work-tree=$HOME config share.target <branch>
# Usage: df-share [sha]         (default: HEAD of current dotfiles branch)
#        df-share <sha> <branch>  (override target branch)
df-share() {
  local src_sha src_branch dst_branch wt
  src_sha=$(/usr/bin/git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" rev-parse --verify "${1:-HEAD}") || return 1
  src_branch=$(/usr/bin/git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" rev-parse --abbrev-ref HEAD) || return 1
  dst_branch=$2
  if [ -z "$dst_branch" ]; then
    if /usr/bin/git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" config --get share.target >/dev/null 2>&1; then
      dst_branch=$(/usr/bin/git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" config --get share.target)
      if [ -z "${dst_branch// }" ]; then
        echo "df-share: share.target is set but empty — fix it: git --git-dir=$HOME/.dotfiles --work-tree=$HOME config share.target <branch>" >&2; return 1
      fi
    else
      echo "df-share: share.target is not set — set it: git --git-dir=$HOME/.dotfiles --work-tree=$HOME config share.target <branch>  (or pass the branch explicitly as the 2nd arg)" >&2; return 1
    fi
  fi
  wt="$HOME/.dotfiles_$dst_branch"
  if [ "$src_branch" = "$dst_branch" ]; then
    echo "df-share: already on $dst_branch, nothing to do" >&2; return 1
  fi
  if [ ! -d "$wt" ]; then
    echo "→ creating worktree $wt for $dst_branch"
    /usr/bin/git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" fetch origin "$dst_branch" || return 1
    /usr/bin/git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" worktree add --track -B "$dst_branch" "$wt" "origin/$dst_branch" || return 1
  fi
  echo "→ push $src_branch"
  /usr/bin/git --git-dir="$HOME/.dotfiles" --work-tree="$HOME" push origin "$src_branch" || return 1
  echo "→ cherry-pick $src_sha onto $dst_branch in $wt"
  (
    cd "$wt" || exit 1
    git checkout "$dst_branch" || exit 1
    git pull --ff-only origin "$dst_branch" || exit 1
    git cherry-pick "$src_sha" || { echo "cherry-pick stopped — resolve in $wt, then: git cherry-pick --continue && git push" >&2; exit 1; }
    git push origin "$dst_branch"
  )
}

# Cherry-pick a .scripts commit onto the target branch and push it (df-share for the non-bare scripts repo)
# Target branch resolution: <branch> arg > `git config share.target` (required if no arg).
# Set the per-machine target with: git -C ~/.scripts config share.target <branch>
# Usage: scripts-share [sha]          (default: HEAD of current .scripts branch)
#        scripts-share <sha> <branch>  (override target branch)
scripts-share() {
  local repo="$HOME/.scripts" src_sha src_branch dst_branch wt
  src_sha=$(git -C "$repo" rev-parse --verify "${1:-HEAD}") || return 1
  src_branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD) || return 1
  dst_branch=$2
  if [ -z "$dst_branch" ]; then
    if git -C "$repo" config --get share.target >/dev/null 2>&1; then
      dst_branch=$(git -C "$repo" config --get share.target)
      if [ -z "${dst_branch// }" ]; then
        echo "scripts-share: share.target is set but empty — fix it: git -C $repo config share.target <branch>" >&2; return 1
      fi
    else
      echo "scripts-share: share.target is not set — set it: git -C $repo config share.target <branch>  (or pass the branch explicitly as the 2nd arg)" >&2; return 1
    fi
  fi
  wt="$HOME/.scripts_$dst_branch"
  if [ "$src_branch" = "$dst_branch" ]; then
    echo "scripts-share: already on $dst_branch, nothing to do" >&2; return 1
  fi
  if [ ! -d "$wt" ]; then
    echo "→ creating worktree $wt for $dst_branch"
    git -C "$repo" fetch origin "$dst_branch" || return 1
    git -C "$repo" worktree add --track -B "$dst_branch" "$wt" "origin/$dst_branch" || return 1
  fi
  echo "→ push $src_branch"
  git -C "$repo" push origin "$src_branch" || return 1
  echo "→ cherry-pick $src_sha onto $dst_branch in $wt"
  (
    cd "$wt" || exit 1
    git checkout "$dst_branch" || exit 1
    git pull --ff-only origin "$dst_branch" || exit 1
    git cherry-pick "$src_sha" || { echo "cherry-pick stopped — resolve in $wt, then: git cherry-pick --continue && git push" >&2; exit 1; }
    git push origin "$dst_branch"
  )
}

claudeTelegramNotifications() {
  local file=~/.claude/telegram_notifications_enabled
  case "$1" in
    enable)  echo 1 > "$file" && echo 'Claude Telegram notifications enabled' ;;
    disable) echo 0 > "$file" && echo 'Claude Telegram notifications disabled' ;;
    "")
      local state=$(cat "$file" 2>/dev/null)
      [[ "$state" == "1" ]] && echo 'Claude Telegram notifications: enabled' || echo 'Claude Telegram notifications: disabled'
      ;;
    *) echo "Usage: claudeTelegramNotifications [enable|disable]" >&2; return 1 ;;
  esac
}

#STDERR printed in RED. Example: color ping
color()(set -o pipefail;"$@" 2> >(sed $'s,.*,\e[31m&\e[m,'>&2))

#Example of multiple strings with grep (or): grep -E 'str1|str2'
#Search regular files that are executable: find -type f --executable
#Aliases limitation: they don't work with $mod + d
#Find's parameter for directory depth limit is -maxdepth X, not -depth X
#Example of find with multiple file extensions find \( -iname \*.h -o -iname \*.cpp -o -iname \*.c \)

#Warning: in bash functions cannot be oneliners, for compatibility make them 3 lines
# wrap long lines using backslashes
wrap() { 
	perl -pe 's/.{'$(( ${COLUMNS:-80} - 1))'}/$&\\\n/g' -- "$@" 
}
