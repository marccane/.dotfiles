{
  "permissions": {
    "allow": [
      "Read(/tmp/**)",
      "Edit(/tmp/**)",
      "Write(/tmp/**)",
      "WebFetch",
      "WebSearch",
      "Read",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(date)",
      "Bash(env)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(tree *)",
      "Bash(diff *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git blame*)",
      "Bash(git ls-files*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh repo view*)",
      "Bash(ps *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(free *)",
      "Bash(uname *)",
      "Bash(uptime)",
      "Bash(lsblk*)",
      "Bash(lscpu)",
      "Bash(pacman -Q*)",
      "Bash(pacman -Ss *)",
      "Bash(npm ls*)",
      "Bash(pip show *)",
      "Bash(pip list)",
      "Bash(python3 --version)",
      "Bash(node --version)",
      "Bash(make clean *)",
      "Bash(make)",
      "Bash(make -n)",
      "Bash(xxd)",
      "Bash(alacritty --print-events)",
      "Bash(kill %1)",
      "Bash(ps aux *)",
      "Bash(ssh n5 *)",
      "Bash(timeout 5 bash *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Claude needs your approval' 2>/dev/null; paplay --volume=32768 /usr/share/sounds/freedesktop/stereo/window-question.oga 2>/dev/null; grep -qx 1 ~/.claude/telegram_notifications_enabled 2>/dev/null && ~/scripts/sendToTelegramViaBot.sh 'Claude needs your approval' 2>/dev/null; true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Claude has responded' 2>/dev/null; paplay --volume=32768 /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null; grep -qx 1 ~/.claude/telegram_notifications_enabled 2>/dev/null && ~/scripts/sendToTelegramViaBot.sh 'Claude has responded' 2>/dev/null; true",
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "auto"
}
