{
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "editorMode": "normal",
  "preferredNotifChannel": "auto",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Claude needs your approval' 2>/dev/null; paplay /usr/share/sounds/freedesktop/stereo/window-question.oga 2>/dev/null",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Claude has responded' 2>/dev/null; paplay /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null",
            "async": true
          }
        ]
      }
    ]
  }
}
